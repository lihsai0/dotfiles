// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "bindings": {
      // Toogle Zoom using `cmd-esc` instead of `shift-esc`
      "shift-escape": null,
      "cmd-escape": "workspace::ToggleZoom",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": null,
    },
  },
  {
    "context": "os == macos && Workspace",
    "bindings": {
      "cmd-k": null,
    },
  },
  {
    "context": "Dock && !Terminal",
    "bindings": {
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Editor",
    "bindings": {},
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      // Sneak move. Use 2 chars to nav and `;`/`,` for next/prev
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
    },
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "space f f": "file_finder::Toggle",
      "space f b": "tab_switcher::ToggleAll",
      "space cmd-k": "git::ExpandCommitEditor",
    },
  },
  {
    "context": "(vim_mode == normal || vim_mode == helix_select) && !menu",
    "bindings": {
      "shift-c": "vim::HelixDuplicateBelow",
      "alt-shift-c": "vim::HelixDuplicateAbove",
    },
  },
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      "s": "vim::HelixSelectRegex",
      "space s": "vim::PushAddSurrounds",
    },
  },
  {
    "context": "vim_mode == insert && Editor",
    "bindings": {
      // Switch to normal mode when saving
      // "cmd-s": ["workspace::SendKeystrokes", "escape : w enter"],
      "ctrl-e": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": false }],
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "shift shift": "command_palette::Toggle"
    }
  }
]
