// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "kimi": {
      "type": "registry",
    },
  },
  "autosave": "on_window_change",
  "base_keymap": "JetBrains",
  "buffer_font_size": 13.0,
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_fallbacks": ["LXGW WenKai Mono"],
  "colorize_brackets": true,
  "context_servers": {},
  "git_panel": {
    "tree_view": true,
  },
  "indent_guides": {
    "enabled": true,
    "line_width": 4,
    "active_line_width": 6,
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "languages": {
    "CSS": {
      "language_servers": [
        // use tailwindcss as default CSS LSP
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server",
      ],
    },
  },
  "lsp": {},
  "minimap": {
    "show": "auto",
  },
  "show_whitespaces": "all",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light Soft",
    "dark": "Gruvbox Dark Soft",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé",
  },
  "theme_overrides": {
    "Gruvbox Light Soft": {
      "syntax": {
        "boolean": {
          "font_style": "italic",
        },
        "constant": {
          "font_style": "italic",
        },
        "number": {
          "font_style": "italic",
        },
        "keyword": {
          "font_style": "italic",
        },
        "hint": {
          "color": "#61a1abff",
          "font_style": "italic",
          "font_weight": 200,
        },
      },
    },
    "Gruvbox Dark Soft": {
      "syntax": {
        "boolean": {
          "font_style": "italic",
        },
        "constant": {
          "font_style": "italic",
        },
        "number": {
          "font_style": "italic",
        },
        "keyword": {
          "font_style": "italic",
        },
      },
    },
  },
  "terminal": {
    "font_size": 14,
  },
  "use_system_window_tabs": true,
  "ui_font_family": "Maple Mono NF",
  "ui_font_fallbacks": ["LXGW WenKai"],
  "ui_font_size": 14,
  "vim_mode": true,
  // "helix_mode": true
}
